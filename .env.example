# ============================================================
# Velix Frontend — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# Backend API URL (the Express server)
NEXT_PUBLIC_API_URL=http://localhost:3005/api

# ---- Supabase (browser-safe) ----
# Only the anon key is safe for the browser. NEVER use the service_role_key here.
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ---- Upstash Redis (server-side only) ----
# Used by /api/cache route handlers — kept server-side, never exposed to the browser.
# Do NOT prefix these with NEXT_PUBLIC_.
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token
